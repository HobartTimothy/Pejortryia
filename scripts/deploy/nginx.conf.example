# =============================================================================
# Pejortryia nginx 反向代理配置
# =============================================================================
# 作用：对外提供 HTTPS，将请求转发到本地 aiohttp 应用（默认 127.0.0.1:8080）。
#
# URL 映射关系：
#   Telegram 登记的 webhook URL:  https://bot.example.com/webhook
#   WEBHOOK_BASE_URL 设置:        https://bot.example.com
#   WEBHOOK_PATH 设置:             /webhook
#   应用内注册的路径:               POST /webhook  (SimpleRequestHandler)
#                                GET  /health   (存活探针)
#                                GET  /hook     (配置验证)
#
# 使用前替换: server_name、ssl_certificate、ssl_certificate_key、proxy_pass。

# ---------------------------------------------------------------------------
# HTTP → HTTPS 重定向
# ---------------------------------------------------------------------------
server {
    listen 80;
    server_name bot.example.com;

    # Let's Encrypt ACME 验证
    location /.well-known/acme-challenge/ {
        root /var/www/acme;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ---------------------------------------------------------------------------
# HTTPS 主服务
# ---------------------------------------------------------------------------
server {
    listen 443 ssl http2;
    server_name bot.example.com;

    # SSL 证书（推荐 Let's Encrypt certbot 获取）
    ssl_certificate     /etc/ssl/certs/bot.example.com.pem;
    ssl_certificate_key /etc/ssl/private/bot.example.com.key;

    # 现代 TLS 配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # 限制请求体大小（Telegram 推送的 JSON 更新通常 < 100KB）
    client_max_body_size 1m;

    # 访问日志（可选，调试时开启）
    # access_log /var/log/nginx/pejortryia.access.log;
    # error_log  /var/log/nginx/pejortryia.error.log;

    # 代理超时（Telegram 要求快速响应）
    proxy_read_timeout 30s;
    proxy_connect_timeout 5s;

    # -----------------------------------------------------------------------
    # 反向代理 — 所有请求转发到 aiohttp 应用
    # -----------------------------------------------------------------------
    location / {
        proxy_pass http://127.0.0.1:8080;

        # 传递原始请求信息
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 传递 Telegram secret token（若设置 WEBHOOK_SECRET）
        # aiogram 会校验此头，匹配 WEBHOOK_SECRET 时才处理更新
        proxy_pass_request_headers on;
    }
}

# =============================================================================
# 验证步骤
# =============================================================================
# 1. 检查 nginx 配置语法:
#    sudo nginx -t
#
# 2. 重载 nginx:
#    sudo systemctl reload nginx
#
# 3. 验证各端点（从外部访问）:
#    curl -sSf https://bot.example.com/health
#    # → 返回 "ok"
#
#    curl -sSf https://bot.example.com/hook
#    # → 返回 {"status":"ok","message":"配置成功"}
#
# 4. 确认 webhook 已注册（在应用日志中查看）:
#    # 启动时自动执行 set_webhook，URL 为 https://bot.example.com/webhook
#
# 5. Telegram webhook 状态查询:
#    curl -sSf "https://api.telegram.org/bot<TOKEN>/getWebhookInfo"
#    # → 检查 "url" 字段是否与 WEBHOOK_BASE_URL + WEBHOOK_PATH 一致
